#!/usr/bin/env bash
# ============================================================================
# Task Hook: on_close  (FlowForge v0.9)
# 当任务关闭时，自动刷新 proposal 的任务快照 (tasks.snapshot.md)
#
# 协议: $1=issue_id, $2=event_type, stdin=完整 issue JSON
# 部署位置: <project>/.beads/hooks/on_close
# ============================================================================

set -euo pipefail

ISSUE_JSON=$(cat)

PROPOSAL_ID=""
if command -v jq &>/dev/null; then
  PROPOSAL_ID=$(echo "$ISSUE_JSON" | jq -r '.labels[]? // empty | select(startswith("proposal:")) | ltrimstr("proposal:")' 2>/dev/null | head -1)
else
  PROPOSAL_ID=$(echo "$ISSUE_JSON" | grep -oP '"proposal:\K[^"]+' | head -1)
fi

if [ -z "${PROPOSAL_ID:-}" ]; then
  exit 0
fi

flowforge task snapshot --proposal "$PROPOSAL_ID" 2>/dev/null &

exit 0
