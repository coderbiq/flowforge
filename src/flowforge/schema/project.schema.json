{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowforge:project-config@v2",
  "title": "Project 配置",
  "description": "单个 project 的配置文件，定义 wikiRoot、源码目录和扩展规则。每个 project 一个文件，由 config.yaml 的 projects[].config 引用。",
  "type": "object",
  "required": ["wikiRoot", "rules"],
  "properties": {
    "wikiRoot": {
      "type": "string",
      "description": "该 project 的 wiki 根目录路径，相对仓库根。所有归属该 project 的文档都存放在此目录下。"
    },
    "srcDirs": {
      "type": "array",
      "description": "该 project 的源码目录列表（相对仓库根）。design SKILL 通过引用文件落点匹配 project 归属。",
      "items": { "type": "string" },
      "default": []
    },
    "description": {
      "type": "string",
      "description": "项目简介，供 design SKILL 理解 project 用途"
    },
    "keywords": {
      "type": "array",
      "description": "关键词列表。design SKILL 通过 intake/用户描述匹配关键词辅助判定 project 归属。",
      "items": { "type": "string" },
      "default": []
    },
    "rules": {
      "type": "object",
      "description": "该 project 的规则配置。每个 SKILL 通过 strategy 字段接收项目级的行为指导文本。",
      "required": ["intake", "design", "implement", "archive", "feedback", "library"],
      "properties": {
        "intake": {
          "type": "object",
          "description": "读取 intake 时的分析策略",
          "properties": {
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何分析 intake 材料的文本策略"
            }
          }
        },
        "design": {
          "type": "object",
          "required": ["naming", "task_rules"],
          "properties": {
            "naming": {
              "type": "object",
            "required": ["proposal_id"],
            "properties": {
              "proposal_id": { "type": "string" }
            }
            },
            "task_rules": {
              "type": "object",
              "required": ["fields", "time_estimate"],
              "properties": {
                "fields": { "type": "array", "items": { "type": "string" } },
                "time_estimate": { "type": "string" }
              }
            },
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何进行方案分析和设计决策的文本策略"
            }
          }
        },
        "implement": {
          "type": "object",
          "required": ["task_states", "notes"],
          "properties": {
            "task_states": { "type": "array", "items": { "type": "string" } },
            "notes": {
              "type": "object",
              "required": ["fields"],
              "properties": {
                "fields": { "type": "array", "items": { "type": "string" } }
              }
            },
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何执行实施工作的文本策略"
            }
          }
        },
        "archive": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何沉淀知识和归档的文本策略"
            }
          }
        },
        "feedback": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何捕获和回流发现的文本策略"
            }
          }
        },
        "library": {
          "type": "object",
          "properties": {
            "requireReview": { "type": "boolean", "default": false },
            "autoUpdateHistory": { "type": "boolean", "default": true },
            "strategy": {
              "type": "string",
              "description": "指导 Agent 如何组织和管理 library 知识的文本策略"
            }
          }
        }
      }
    }
  }
}
