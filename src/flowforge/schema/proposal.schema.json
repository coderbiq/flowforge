{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowforge:proposal-meta@v1",
  "title": "提案 Meta 契约",
  "description": "proposal 目录下 meta.yaml 的结构定义，描述提案容器级别的元信息。",
  "type": "object",
  "required": ["id", "title", "status", "project", "created_at", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CR[0-9]{8}$",
      "description": "变更请求 ID，格式 CRYYMMDDNN"
    },
    "title": {
      "type": "string",
      "description": "提案标题"
    },
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "提案归属的 project id，引用 config.yaml projects[].id。一次性决策，proposal 创建后不应变更。下游 SKILL/脚本通过此字段定位该 proposal 所属的 wikiRoot。"
    },
    "status": {
      "type": "string",
      "description": "提案状态，可在以下状态间任意流转",
      "enum": ["draft", "active", "implemented", "archived", "rejected"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "size_class": {
      "type": "string",
      "enum": ["small", "medium", "large"],
      "description": "提案规模，影响 design 文档的拆分方式"
    },
    "modules": {
      "type": "array",
      "description": "涉及的模块名称列表，仅用于 INDEX.md 展示。每个元素为模块名（如 auth、payment）。",
      "items": { "type": "string" },
      "default": []
    },
    "latest_progress": {
      "type": "string",
      "maxLength": 100,
      "description": "最近一次工作单元的进度总结，由 flowforge-progress SKILL 在完成工作后自动写入，一句话描述"
    },
    "task_backend": {
      "type": "object",
      "description": "任务跟踪后端",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["beads", "github", "linear", "jira", "none"],
          "default": "none"
        },
        "epic_id": { "type": "string" }
      }
    },
    "links": {
      "type": "object",
      "description": "提案目录内各文件的链接",
      "properties": {
        "proposal": { "type": "string", "default": "proposal.md" },
        "design": { "type": "string", "default": "design.md" },
        "task_snapshot": { "type": "string", "default": "tasks.snapshot.md" },
        "notes": { "type": "string", "default": "notes.md" }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "自由标签"
    }
  }
}
