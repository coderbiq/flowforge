{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowforge:frontmatter@v1",
  "title": "文档 Frontmatter 契约",
  "description": "每个 wiki 文档必须携带的通用 frontmatter 字段。类型专属字段由各自的 schema 补充。",
  "type": "object",
  "required": ["doc_type", "title", "status", "created", "updated"],
  "properties": {
    "doc_type": {
      "type": "string",
      "description": "文档类型，决定文档在 wiki 中的角色和存放位置",
      "enum": [
        "intake",
        "finding",
        "decision",
        "proposal",
        "design",
        "model",
        "task-map",
        "notes",
        "module",
        "architecture",
        "convention",
        "adr"
      ]
    },
    "title": {
      "type": "string",
      "description": "人类可读标题"
    },
    "status": {
      "type": "string",
      "description": "生命周期状态，不同 doc_type 有各自的合法值集合",
      "enum": [
        "draft",
        "active",
        "archived",
        "rejected",
        "superseded",
        "deprecated",
        "accepted"
      ]
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间，ISO-8601"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "最后更新时间，ISO-8601"
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" },
      "description": "用于搜索和图谱的自由标签"
    },
    "domain": {
      "type": "object",
      "description": "知识分类对象，决定该文档在归档时的目标位置。文档不含可归档知识时省略此字段（如 proposal、task-map、journal、notes）。",
      "required": ["scope", "type"],
      "properties": {
        "scope": { "type": "string", "enum": ["system", "module"], "description": "全系统或某个模块" },
        "module": { "type": "string", "description": "模块名，仅 scope=module 时需要" },
        "type": { "type": "string", "enum": ["design", "decision", "convention"], "description": "设计 / 决策 / 约定" },
        "importance": { "type": "string", "enum": ["must", "should", "may", "info"], "default": "should", "description": "重要度：must=铁律 should=建议 may=参考 info=备忘" },
        "maturity": { "type": "string", "enum": ["seed", "growing", "stable", "deprecated"], "default": "growing", "description": "成熟度：seed=骨架 growing=成长中 stable=成熟 deprecated=废弃" }
      }
    },
    "review_interval": {
      "type": "number",
      "default": 180,
      "description": "内容审查间隔（天），超过触发 stale 标记"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date-time",
      "description": "上次审查时间，ISO-8601"
    },
    "covers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "文档覆盖的源文件 glob 模式，用于 code_changes 过期检测"
    },
    "related": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": { "type": "string", "description": "关联文档的相对路径引用" },
          "role": { "type": "string", "description": "关联角色，如 source、derived、reference" }
        }
      },
      "description": "关联的其他文档引用"
    }
  }
}
