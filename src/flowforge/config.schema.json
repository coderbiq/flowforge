{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowforge:config@v2",
  "title": "FlowForge 项目配置",
  "description": "安装到 .flowforge/config.yaml 的主配置，定义 projects 索引和全局基础设施设置。每个 project 的详细配置在独立文件中，由 projects[].config 引用。",
  "type": "object",
  "required": ["projects"],
  "properties": {
    "projects": {
      "type": "array",
      "description": "项目列表。每个 project 通过 config 字段引用独立的配置文件（路径相对 .flowforge/）。",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "config"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "项目唯一标识，作为 meta.yaml.project 的引用值。建议使用 kebab-case。"
          },
          "name": {
            "type": "string",
            "description": "项目展示名称"
          },
          "config": {
            "type": "string",
            "description": "project 配置文件的路径，相对 .flowforge/ 目录（如 projects/web.yaml）"
          }
        }
      }
    },
    "taskBackend": {
      "type": "object",
      "description": "任务跟踪后端配置（全局）",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["beads", "github", "linear", "jira", "none"],
          "default": "none"
        },
        "config": {
          "type": "object",
          "description": "后端特定的配置参数"
        }
      }
    },
    "memoryProvider": {
      "type": "object",
      "description": "外部记忆提供者配置（全局）",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "type": { "type": "string" },
        "config": { "type": "object" }
      }
    }
  }
}
