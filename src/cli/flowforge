function printVersion() {
  try {
    const meta = require(path.join(projectRoot, '.flowforge', 'meta.yaml'));
    console.log(`FlowForge v${meta.version || '0.9.0'}`);
  } catch (_) {
    console.log('FlowForge v0.13.0');
  }
}

