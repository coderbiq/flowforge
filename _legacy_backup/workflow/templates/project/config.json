  "task_backend": {
    "type": "beads"
  },
  "memory_provider": {
    "type": "memory-mcp",
    "enabled": false,
    "endpoint": "http://127.0.0.1:8000",
    "tags": [
      "project:your-project"
    ]
  }
}
